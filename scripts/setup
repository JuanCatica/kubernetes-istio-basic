#!/usr/bin/env bash
# Environment check (flutter doctor–style output).

set -euo pipefail

issues=0
missing_brew=()

# Colors when stdout is a TTY (no escape noise in logs / pipes).
if [[ -t 1 ]]; then
  clr_ok=$'\033[32m'         # green — summary success
  brew_hint_clr=$'\033[1;34m' # bold blue — Homebrew intro
  brew_cmd_clr=$'\033[1;32m'  # bold green — brew install command
  brew_cmt_clr=$'\033[90m'   # gray — Docker Desktop comment
  clr_rst=$'\033[0m'
else
  clr_ok= brew_hint_clr= brew_cmd_clr= brew_cmt_clr= clr_rst=
fi

section_line() {
  printf '%s\n' "────────────────────────────────────────────────────────────"
}

header() {
  printf '\n'
  printf '%s\n' "Environment check to run Istio Basic"
  section_line
  printf '\n'
}

print_ok() {
  local title="$1"
  local detail="$2"
  printf '[✓] %s' "$title"
  if [[ -n "$detail" ]]; then
    printf ' (%s)' "$detail"
  fi
  printf '\n'
}

print_warn() {
  local title="$1"
  local detail="$2"
  printf '[!] %s\n' "$title"
  if [[ -n "$detail" ]]; then
    printf '    ! %s\n' "$detail"
  fi
  issues=$((issues + 1))
}

print_fail() {
  local title="$1"
  local detail="$2"
  printf '[✗] %s\n' "$title"
  if [[ -n "$detail" ]]; then
    printf '    %s\n' "$detail"
  fi
  issues=$((issues + 1))
}

# Maps CLI name to the argument Homebrew expects on `brew install …`.
brew_pkg_for_binary() {
  case "$1" in
    curl) printf '%s\n' curl ;;
    docker) printf '%s\n' docker ;;
    hey) printf '%s\n' hey ;;
    istioctl) printf '%s\n' istioctl ;;
    k9s) printf '%s\n' derailed/k9s/k9s ;;
    kind) printf '%s\n' kind ;;
    kubectl) printf '%s\n' kubectl ;;
    watch) printf '%s\n' watch ;;
    *) return 1 ;;
  esac
}

# check_program TITLE BINARY INSTALL_HINT [VERSION_SHELL]
# VERSION_SHELL: optional shell snippet run via bash -c to produce version text (first line used).
# If omitted, runs BINARY --version.
check_program() {
  local title="$1"
  local binary="$2"
  local install_hint="$3"
  local detail=""

  if ! command -v "$binary" &>/dev/null; then
    print_fail "$title" "${binary} not found in PATH. ${install_hint}"
    local pkg
    pkg="$(brew_pkg_for_binary "$binary" 2>/dev/null || true)"
    [[ -n "$pkg" ]] && missing_brew+=("$pkg")
    return
  fi

  if (($# >= 4)); then
    detail="$(bash -c "$4" 2>/dev/null | head -n 1 | tr -d '\r' || true)"
  else
    detail="$("$binary" --version 2>/dev/null | head -n 1 | tr -d '\r' || true)"
  fi
  [[ -z "$detail" ]] && detail="installed"
  print_ok "$title" "$detail"
}

header

# --- Docker (required for Kind in this tutorial) ---
check_program "Docker" docker \
  "See https://docs.docker.com/get-docker/ — on macOS, Homebrew: brew install --cask docker (Docker Desktop) or brew install docker"

# --- curl ---
check_program "curl" curl "See https://curl.se/docs/install.html"

# --- Kind (Kubernetes in Docker) ---
check_program "Kind" kind "See https://kind.sigs.k8s.io/docs/user/quick-start/#installation" \
  "kind version 2>/dev/null | head -n 1 | tr -d '\r'"

# --- kubectl ---
check_program "kubectl" kubectl "See https://kubernetes.io/docs/tasks/tools/" \
  'v=$(kubectl version --client -o jsonpath='\''{.clientVersion.gitVersion}'\'' 2>/dev/null || true); [[ -n "$v" ]] && echo "$v" || kubectl version --client 2>/dev/null | head -n 1 | tr -d '\''\r'\'''

# --- Istio ---
check_program "Istio" istioctl "See https://istio.io/latest/docs/setup/getting-started/" \
  "istioctl version --remote=false 2>/dev/null | head -n 1 | tr -d '\r'"

# --- watch ---
check_program "Watch" watch "See https://linux.die.net/man/1/watch"

# --- hey (HTTP load generator) ---
check_program "Hey" hey "See https://github.com/rakyll/hey"

# --- k9s (terminal UI for Kubernetes) ---
# k9s version (no --short) prints a banner first; --short skips art but still lists Version on line 1.
check_program "k9s" k9s "See https://k9scli.io/ — Homebrew: brew install derailed/k9s/k9s" \
  "k9s version --short 2>/dev/null | awk '/^Version/{print \$NF; exit}' | tr -d '\r'"

# --- Summary ---
printf '\n'
section_line
if (( issues == 0 )); then
  printf '%s%s%s\n' "$clr_ok" "No issues found!" "$clr_rst"
else
  if (( issues == 1 )); then
    printf '%s\n' "Setup found issues in 1 category."
  else
    printf '%s\n' "Setup found issues in ${issues} categories."
  fi
fi

if ((${#missing_brew[@]} > 0)); then
  # Order matches typical one-liner: kind … kubectl … istioctl … watch … curl … hey … k9s … docker
  brew_order=(kind kubectl istioctl watch curl hey derailed/k9s/k9s docker)
  to_install=()
  for p in "${brew_order[@]}"; do
    for m in "${missing_brew[@]}"; do
      if [[ "$m" == "$p" ]]; then
        to_install+=("$p")
        break
      fi
    done
  done
  if ((${#to_install[@]} > 0)); then
    printf '\n'
    printf '%s%s%s\n' "$brew_hint_clr" "Install everything reported above with Homebrew (macOS). Copy and run:" "$clr_rst"
    printf '%s  brew install %s%s\n' "$brew_cmd_clr" "${to_install[*]}" "$clr_rst"
    if [[ " ${to_install[*]} " == *" docker "* ]]; then
      printf '%s%s%s\n' "$brew_cmt_clr" "  # Prefer Docker Desktop? Use: brew install --cask docker (then rerun this check)." "$clr_rst"
    fi
  fi
fi

printf '\n'
